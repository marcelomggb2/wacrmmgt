# Copy this file to .env.vps on the VPS.
# Keep .env.vps private; only this example file belongs in Git.

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

ENCRYPTION_KEY=your-64-char-hex-key
META_APP_SECRET=your-meta-app-secret
META_APP_ID=your-meta-app-id
META_GRAPH_API_VERSION=v23.0

NEXT_PUBLIC_SITE_URL=https://crm.example.com
NEXT_PUBLIC_INSTAGRAM_WEBHOOK_ORIGIN=https://ig-hooks.example.com
ALLOWED_INVITE_HOSTS=crm.example.com,ig-hooks.example.com

AUTOMATION_CRON_SECRET=generate-a-long-random-string
WHATSAPP_TEMPLATES_DRY_RUN=false

# Internal container networking.
REDIS_URL=redis://redis:6379/0
INTERNAL_APP_ORIGIN=http://app:3000
INTERNAL_WORKER_ENDPOINT=http://app:3000/api/internal/workers/messages
INTERNAL_WORKER_TOKEN=generate-a-long-random-string
MESSAGE_QUEUE_NAMES=meta:webhooks,instagram:webhooks,whatsapp:webhooks
MESSAGE_DEAD_LETTER_QUEUE=meta:webhooks:dead
